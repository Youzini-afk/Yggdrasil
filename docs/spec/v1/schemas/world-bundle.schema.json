{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "ProtocolProfilePin": {
      "properties": {
        "profile": {
          "type": "string"
        },
        "protocol_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "profile",
        "protocol_id",
        "version"
      ],
      "type": "object"
    },
    "WorldBundleManifest": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "type": "object"
        },
        "bundle_type_uri": {
          "type": "string"
        },
        "composition_lock": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "effect_receipts": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "journal_ranges": {
          "items": {
            "$ref": "#/$defs/WorldJournalRange"
          },
          "type": "array"
        },
        "lineage": {
          "items": {
            "$ref": "#/$defs/WorldLineageEntry"
          },
          "type": "array"
        },
        "object_descriptors": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "original_v1_envelopes": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "policy_refs": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "protocol_id": {
          "type": "string"
        },
        "protocol_profile": {
          "type": "string"
        },
        "protocol_profiles": {
          "items": {
            "$ref": "#/$defs/ProtocolProfilePin"
          },
          "type": "array"
        },
        "protocol_version": {
          "type": "string"
        },
        "schema_version": {
          "format": "uint16",
          "minimum": 0.0,
          "type": "integer"
        },
        "world_head": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "world_id": {
          "type": "string"
        }
      },
      "required": [
        "bundle_type_uri",
        "composition_lock",
        "journal_ranges",
        "lineage",
        "object_descriptors",
        "original_v1_envelopes",
        "protocol_id",
        "protocol_profile",
        "protocol_profiles",
        "protocol_version",
        "schema_version",
        "world_head",
        "world_id"
      ],
      "type": "object"
    },
    "WorldBundleObject": {
      "properties": {
        "data_base64": {
          "type": "string"
        },
        "descriptor": {
          "$ref": "#/$defs/ArtifactDescriptor"
        }
      },
      "required": [
        "data_base64",
        "descriptor"
      ],
      "type": "object"
    },
    "WorldJournalRange": {
      "properties": {
        "envelope_refs": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "first_sequence": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "last_sequence": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "session_id": {
          "type": "string"
        }
      },
      "required": [
        "envelope_refs",
        "first_sequence",
        "last_sequence",
        "session_id"
      ],
      "type": "object"
    },
    "WorldLineageEntry": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "type": "object"
        },
        "effect_receipts": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "head": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "parent_heads": {
          "items": {
            "$ref": "#/$defs/ArtifactDescriptor"
          },
          "type": "array"
        },
        "relation": {
          "type": "string"
        }
      },
      "required": [
        "head",
        "relation"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "archive_format": {
      "type": "string"
    },
    "bundle_descriptor": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "manifest": {
      "$ref": "#/$defs/WorldBundleManifest"
    },
    "objects": {
      "items": {
        "$ref": "#/$defs/WorldBundleObject"
      },
      "type": "array"
    }
  },
  "required": [
    "archive_format",
    "bundle_descriptor",
    "manifest",
    "objects"
  ],
  "title": "WorldBundleArchive",
  "type": "object"
}
