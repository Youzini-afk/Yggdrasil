{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "EffectReplayMode": {
      "enum": [
        "live",
        "historical",
        "reexecute"
      ],
      "type": "string"
    },
    "EffectScope": {
      "properties": {
        "branch_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "EffectTerminalStatus": {
      "enum": [
        "succeeded",
        "denied",
        "failed",
        "cancelled",
        "timed_out",
        "partial"
      ],
      "type": "string"
    },
    "PrincipalIdentity": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "kernel"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "host_admin"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "host_dev"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "package"
              ],
              "type": "string"
            },
            "package_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "package_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "human"
              ],
              "type": "string"
            },
            "user_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "user_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "assistant_id": {
              "type": "string"
            },
            "delegated_user_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "assistant"
              ],
              "type": "string"
            }
          },
          "required": [
            "assistant_id",
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "anonymous"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "actual": {
      "default": null
    },
    "annotations": {
      "additionalProperties": true,
      "default": {},
      "type": "object"
    },
    "approval_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        {
          "type": "null"
        }
      ]
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "component_ref": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "cost": {
      "default": null
    },
    "effect_kind": {
      "type": "string"
    },
    "external_effect_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "input_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "latency_ms": {
      "format": "uint64",
      "minimum": 0.0,
      "type": "integer"
    },
    "output_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "parent_receipts": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "planned": {
      "default": null
    },
    "policy_decision_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        {
          "type": "null"
        }
      ]
    },
    "principal": {
      "$ref": "#/$defs/PrincipalIdentity"
    },
    "protocol_profiles": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "receipt_id": {
      "type": "string"
    },
    "receipt_type_uri": {
      "type": "string"
    },
    "replay_mode": {
      "$ref": "#/$defs/EffectReplayMode"
    },
    "schema_version": {
      "format": "uint16",
      "minimum": 0.0,
      "type": "integer"
    },
    "scope": {
      "allOf": [
        {
          "$ref": "#/$defs/EffectScope"
        }
      ],
      "default": {}
    },
    "started_at": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/EffectTerminalStatus"
    },
    "trace_id": {
      "type": "string"
    },
    "usage": {
      "default": null
    }
  },
  "required": [
    "completed_at",
    "component_ref",
    "effect_kind",
    "latency_ms",
    "principal",
    "receipt_id",
    "receipt_type_uri",
    "replay_mode",
    "schema_version",
    "started_at",
    "status",
    "trace_id"
  ],
  "title": "EffectReceipt",
  "type": "object"
}
