{
  "$defs": {
    "AssetPermissions": {
      "properties": {
        "read": {
          "default": false,
          "type": "boolean"
        },
        "write": {
          "default": false,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "CapabilityDescriptor": {
      "properties": {
        "description": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "input_schema": {
          "default": null
        },
        "output_schema": {
          "default": null
        },
        "side_effects": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "streaming": {
          "default": false,
          "type": "boolean"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "version"
      ],
      "type": "object"
    },
    "CapabilityPermissions": {
      "properties": {
        "invoke": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "CapabilityRequirement": {
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "version"
      ],
      "type": "object"
    },
    "ContractMode": {
      "oneOf": [
        {
          "description": "Path A: full v1 contract enforcement (default).",
          "enum": [
            "v1"
          ],
          "type": "string"
        },
        {
          "description": "Path B: self-contained app — kernel hosts process, no contract enforcement.",
          "enum": [
            "none"
          ],
          "type": "string"
        }
      ]
    },
    "DependencySource": {
      "oneOf": [
        {
          "description": "Built-in to Yggdrasil (no fetch needed; resolves at host runtime)",
          "properties": {
            "kind": {
              "enum": [
                "internal"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Fetched from a git remote",
          "properties": {
            "kind": {
              "enum": [
                "git"
              ],
              "type": "string"
            },
            "ref": {
              "default": "",
              "description": "Tag, branch, or commit ref",
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "url"
          ],
          "type": "object"
        },
        {
          "description": "Local filesystem path (for development)",
          "properties": {
            "kind": {
              "enum": [
                "local"
              ],
              "type": "string"
            },
            "path": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "EntryDescriptor": {
      "oneOf": [
        {
          "properties": {
            "abi_version": {
              "format": "uint16",
              "minimum": 0.0,
              "type": "integer"
            },
            "crate_ref": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "rust_inproc"
              ],
              "type": "string"
            },
            "symbol": {
              "type": "string"
            }
          },
          "required": [
            "abi_version",
            "crate_ref",
            "kind",
            "symbol"
          ],
          "type": "object"
        },
        {
          "properties": {
            "command": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "kind": {
              "enum": [
                "subprocess"
              ],
              "type": "string"
            },
            "transport": {
              "allOf": [
                {
                  "$ref": "#/$defs/SubprocessTransport"
                }
              ],
              "default": "json_rpc_stdio"
            }
          },
          "required": [
            "command",
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "abi_version": {
              "format": "uint16",
              "minimum": 0.0,
              "type": "integer"
            },
            "kind": {
              "enum": [
                "wasm"
              ],
              "type": "string"
            },
            "memory_limit_mb": {
              "format": "uint64",
              "minimum": 0.0,
              "type": "integer"
            },
            "module": {
              "type": "string"
            }
          },
          "required": [
            "abi_version",
            "kind",
            "memory_limit_mb",
            "module"
          ],
          "type": "object"
        },
        {
          "properties": {
            "auth": {
              "$ref": "#/$defs/RemoteAuth"
            },
            "endpoint": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "remote"
              ],
              "type": "string"
            }
          },
          "required": [
            "auth",
            "endpoint",
            "kind"
          ],
          "type": "object"
        },
        {
          "description": "Static surface bundle package. This entry is not executed by the host; it contributes surfaces and optional static assets only.",
          "properties": {
            "bundle": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "surface_bundle"
              ],
              "type": "string"
            }
          },
          "required": [
            "bundle",
            "kind"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "contract": {
          "allOf": [
            {
              "$ref": "#/$defs/ContractMode"
            }
          ],
          "default": "v1",
          "description": "Path A (`v1`) enforces the Yggdrasil package contract. Path B (`none`) is a self-contained app hosted by the kernel without manifest contract enforcement."
        }
      },
      "type": "object"
    },
    "Errors": {
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "code": {
            "type": "string"
          },
          "details": true,
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "details",
          "message"
        ],
        "title": "ErrorShape",
        "type": "object"
      },
      "type": "array"
    },
    "EventPermissions": {
      "properties": {
        "append": {
          "default": false,
          "type": "boolean"
        },
        "read": {
          "default": false,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "ExtensionPointDescriptor": {
      "properties": {
        "id": {
          "type": "string"
        },
        "modifiable": {
          "type": "boolean"
        },
        "payload_schema": {
          "default": null
        },
        "short_circuit": {
          "type": "boolean"
        },
        "timing": {
          "$ref": "#/$defs/HookTiming"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "modifiable",
        "short_circuit",
        "timing",
        "version"
      ],
      "type": "object"
    },
    "FilesystemPermissions": {
      "properties": {
        "read": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "write": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "HookSubscription": {
      "properties": {
        "extension_point": {
          "type": "string"
        },
        "handler": {
          "type": "string"
        },
        "precedence": {
          "default": 0,
          "format": "int32",
          "type": "integer"
        },
        "timing": {
          "$ref": "#/$defs/HookTiming"
        }
      },
      "required": [
        "extension_point",
        "handler",
        "timing"
      ],
      "type": "object"
    },
    "HookTiming": {
      "enum": [
        "sync",
        "async"
      ],
      "type": "string"
    },
    "LocalExecDeclaration": {
      "properties": {
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "programs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_id": {
          "type": "string"
        }
      },
      "required": [
        "target_id"
      ],
      "type": "object"
    },
    "LocalExecPermissions": {
      "properties": {
        "declarations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/LocalExecDeclaration"
          },
          "type": "array"
        },
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "NetworkDeclaration": {
      "description": "A single network access declaration in a package manifest.\n\nEach entry describes an allowed outbound destination with host, permitted HTTP methods, and a human-readable purpose. The runtime / host policy checker matches outbound requests against declared entries. Packages with no `network` declarations must not make any outbound network requests.",
      "properties": {
        "host": {
          "description": "Destination host (e.g. `\"api.openai.com\"` or `\"*.example.org\"`).",
          "type": "string"
        },
        "methods": {
          "default": [],
          "description": "Permitted HTTP/WebSocket methods (e.g. `[\"GET\", \"POST\", \"WEBSOCKET\"]`). Empty means all.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "purpose": {
          "default": null,
          "description": "Human-readable purpose for this network access.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "host"
      ],
      "type": "object"
    },
    "NetworkPermissions": {
      "properties": {
        "declarations": {
          "default": [],
          "description": "Structured network declarations (host, methods, purpose).",
          "items": {
            "$ref": "#/$defs/NetworkDeclaration"
          },
          "type": "array"
        },
        "hosts": {
          "default": [],
          "description": "Flat host list for backward compatibility. Packages using the structured form should populate `declarations` instead.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PackageContributions": {
      "properties": {
        "extension_points": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ExtensionPointDescriptor"
          },
          "type": "array"
        },
        "hooks": {
          "default": [],
          "items": {
            "$ref": "#/$defs/HookSubscription"
          },
          "type": "array"
        },
        "schemas": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SchemaContribution"
          },
          "type": "array"
        },
        "surfaces": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SurfaceContribution"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PackageDependency": {
      "properties": {
        "id": {
          "description": "Logical package id (must match the dependency's manifest.id once resolved)",
          "type": "string"
        },
        "minimum_signed_by": {
          "description": "Optional: GPG public key fingerprints required to sign this dep If empty, no signature verification required If set, the dep's GPG-signed tag must be signed by one of these",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "allOf": [
            {
              "$ref": "#/$defs/DependencySource"
            }
          ],
          "description": "Where the package comes from"
        },
        "version": {
          "default": "",
          "description": "Semver constraint (e.g., \">=1.0.0\", \"^2.1\", \"=1.2.3\") Empty string means \"any version\"",
          "type": "string"
        }
      },
      "required": [
        "id",
        "source"
      ],
      "type": "object"
    },
    "PackageFailureSummary": {
      "properties": {
        "exit_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "failed_at": {
          "format": "date-time",
          "type": "string"
        },
        "log_tail_redacted": {
          "items": {
            "$ref": "#/$defs/SubprocessLogLine"
          },
          "type": "array"
        },
        "package_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "redaction_state": {
          "$ref": "#/$defs/RedactionState"
        },
        "signal": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/$defs/PackageState"
        },
        "stderr_tail_redacted": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "stderr_truncated": {
          "type": "boolean"
        }
      },
      "required": [
        "failed_at",
        "log_tail_redacted",
        "package_id",
        "reason",
        "redaction_state",
        "state",
        "stderr_tail_redacted",
        "stderr_truncated"
      ],
      "type": "object"
    },
    "PackageManifest": {
      "properties": {
        "author": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "consumes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/CapabilityRequirement"
          },
          "type": "array"
        },
        "contributes": {
          "allOf": [
            {
              "$ref": "#/$defs/PackageContributions"
            }
          ],
          "default": {
            "extension_points": [],
            "hooks": [],
            "schemas": [],
            "surfaces": []
          }
        },
        "description": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "display_name": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "entry": {
          "$ref": "#/$defs/EntryDescriptor"
        },
        "id": {
          "type": "string"
        },
        "license": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "permissions": {
          "allOf": [
            {
              "$ref": "#/$defs/PermissionSet"
            }
          ],
          "default": {
            "assets": {
              "read": false,
              "write": false
            },
            "capabilities": {
              "invoke": []
            },
            "events": {
              "append": false,
              "read": false
            },
            "filesystem": {
              "read": [],
              "write": []
            },
            "local_exec": {
              "declarations": [],
              "max_count": null
            },
            "network": {
              "declarations": [],
              "hosts": []
            },
            "packages": {
              "call": []
            },
            "ports": {
              "declarations": [],
              "max_count": null
            },
            "proxy": {
              "declarations": [],
              "max_count": null
            },
            "secret_refs": []
          }
        },
        "provides": {
          "default": [],
          "items": {
            "$ref": "#/$defs/CapabilityDescriptor"
          },
          "type": "array"
        },
        "requires": {
          "description": "First-class package dependency declarations. Distinct from `consumes` (which declares capability requirements). Empty by default for backward compat.",
          "items": {
            "$ref": "#/$defs/PackageDependency"
          },
          "type": "array"
        },
        "sandbox_policy": {
          "allOf": [
            {
              "$ref": "#/$defs/SandboxPolicy"
            }
          ],
          "default": {
            "cpu_quota_ms_per_invoke": 5000,
            "memory_mb": 128,
            "wall_clock_ms": 30000
          }
        },
        "schema_version": {
          "format": "uint16",
          "minimum": 0.0,
          "type": "integer"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "entry",
        "id",
        "schema_version",
        "version"
      ],
      "type": "object"
    },
    "PackagePermissions": {
      "properties": {
        "call": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PackageState": {
      "enum": [
        "discovered",
        "loading",
        "starting",
        "ready",
        "degraded",
        "stopping",
        "stopped",
        "unloaded"
      ],
      "type": "string"
    },
    "Params": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "package_id": {
          "type": "string"
        }
      },
      "required": [
        "package_id"
      ],
      "title": "PackageIdParams",
      "type": "object"
    },
    "PermissionSet": {
      "properties": {
        "assets": {
          "allOf": [
            {
              "$ref": "#/$defs/AssetPermissions"
            }
          ],
          "default": {
            "read": false,
            "write": false
          }
        },
        "capabilities": {
          "allOf": [
            {
              "$ref": "#/$defs/CapabilityPermissions"
            }
          ],
          "default": {
            "invoke": []
          }
        },
        "events": {
          "allOf": [
            {
              "$ref": "#/$defs/EventPermissions"
            }
          ],
          "default": {
            "append": false,
            "read": false
          }
        },
        "filesystem": {
          "allOf": [
            {
              "$ref": "#/$defs/FilesystemPermissions"
            }
          ],
          "default": {
            "read": [],
            "write": []
          }
        },
        "local_exec": {
          "allOf": [
            {
              "$ref": "#/$defs/LocalExecPermissions"
            }
          ],
          "default": {
            "declarations": [],
            "max_count": null
          }
        },
        "network": {
          "allOf": [
            {
              "$ref": "#/$defs/NetworkPermissions"
            }
          ],
          "default": {
            "declarations": [],
            "hosts": []
          }
        },
        "packages": {
          "allOf": [
            {
              "$ref": "#/$defs/PackagePermissions"
            }
          ],
          "default": {
            "call": []
          }
        },
        "ports": {
          "allOf": [
            {
              "$ref": "#/$defs/PortPermissions"
            }
          ],
          "default": {
            "declarations": [],
            "max_count": null
          }
        },
        "proxy": {
          "allOf": [
            {
              "$ref": "#/$defs/ProxyPermissions"
            }
          ],
          "default": {
            "declarations": [],
            "max_count": null
          }
        },
        "secret_refs": {
          "default": [],
          "description": "Declared secret references this package may use in `kernel.v1.outbound.execute` calls. Each entry must be a valid env-backed secret reference (e.g. `secret_ref:env:OPENAI_API_KEY`, `secretRef:env:MY_KEY`, `secret-ref:env:NAME`, `host:env:NAME`).\n\nThe runtime enforces fail-closed: any `secret_ref` used in `secret_headers` or top-level `secret_refs` at dispatch time **must** appear in this list, or the request is denied.\n\nDefault: empty vec (no secret refs allowed; backward compatible).",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "PortDeclaration": {
      "properties": {
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "port_names": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_id": {
          "type": "string"
        }
      },
      "required": [
        "target_id"
      ],
      "type": "object"
    },
    "PortPermissions": {
      "properties": {
        "declarations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PortDeclaration"
          },
          "type": "array"
        },
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "ProxyDeclaration": {
      "properties": {
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "route_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ProxyPermissions": {
      "properties": {
        "declarations": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ProxyDeclaration"
          },
          "type": "array"
        },
        "max_count": {
          "default": null,
          "format": "uint32",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "RedactionState": {
      "description": "Redaction state for an outbound audit record.\n\nEvery outbound request carries one of these states to indicate whether raw body/header/prompt/response data was preserved. The default is `NotCaptured` — raw data is never saved unless explicitly approved.",
      "oneOf": [
        {
          "description": "Raw data was not captured (default).",
          "enum": [
            "not_captured"
          ],
          "type": "string"
        },
        {
          "description": "Raw data was redacted before recording.",
          "enum": [
            "redacted"
          ],
          "type": "string"
        },
        {
          "description": "Only a policy reference is stored; no data captured.",
          "enum": [
            "policy_ref"
          ],
          "type": "string"
        },
        {
          "description": "Request was blocked as unsafe; no data recorded.",
          "enum": [
            "unsafe_blocked"
          ],
          "type": "string"
        },
        {
          "description": "Explicit user/host approval to capture raw data (rare).",
          "enum": [
            "explicitly_approved"
          ],
          "type": "string"
        }
      ]
    },
    "RemoteAuth": {
      "properties": {
        "config": {
          "default": null
        },
        "scheme": {
          "type": "string"
        }
      },
      "required": [
        "scheme"
      ],
      "type": "object"
    },
    "Result": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "capability_count": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "entry_kind": {
          "type": "string"
        },
        "extension_point_count": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
