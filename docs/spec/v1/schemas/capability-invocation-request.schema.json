{
  "$defs": {
    "CapHandleId": {
      "format": "uint128",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "caller_package_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "capability_id": {
      "default": null,
      "description": "Legacy path. Runtime auto-mints a one-use transient handle when no handle is supplied.",
      "type": [
        "string",
        "null"
      ]
    },
    "handle": {
      "anyOf": [
        {
          "$ref": "#/definitions/CapHandleId"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "New preferred path: invoke by kernel-minted handle."
    },
    "input": {
      "default": null
    },
    "provider_package_id": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "session_id": {
      "description": "Kernel session id this invocation is part of, if any. Propagated from ProtocolContext for downstream scope resolution.",
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    }
  },
  "title": "CapabilityInvocationRequest",
  "type": "object"
}
