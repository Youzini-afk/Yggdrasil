{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "ComponentBoundaryClaims": {
      "properties": {
        "filesystem_isolation": {
          "type": "boolean"
        },
        "network_isolation": {
          "type": "boolean"
        },
        "no_code_execution": {
          "type": "boolean"
        },
        "process_failure_isolation": {
          "type": "boolean"
        },
        "remote_identity": {
          "type": "boolean"
        },
        "resource_limits_enforced": {
          "type": "boolean"
        },
        "revocation_enforced": {
          "type": "boolean"
        },
        "tenancy_isolation": {
          "type": "boolean"
        }
      },
      "required": [
        "filesystem_isolation",
        "network_isolation",
        "no_code_execution",
        "process_failure_isolation",
        "remote_identity",
        "resource_limits_enforced",
        "revocation_enforced",
        "tenancy_isolation"
      ],
      "type": "object"
    },
    "ComponentClaimStatus": {
      "enum": [
        "declared",
        "legacy_adapted",
        "foreign_capsule"
      ],
      "type": "string"
    },
    "ComponentTrustClass": {
      "enum": [
        "sandboxed_component",
        "isolated_process",
        "remote_boundary",
        "trusted_native",
        "static_resource",
        "foreign_capsule"
      ],
      "type": "string"
    },
    "PackagedProtocolDescriptor": {
      "properties": {
        "artifact": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "implementation": {
          "$ref": "#/$defs/ProtocolImplementationDeclaration"
        }
      },
      "required": [
        "artifact",
        "implementation"
      ],
      "type": "object"
    },
    "PackagedSurfaceDescriptor": {
      "properties": {
        "artifact": {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        "surface_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "artifact",
        "surface_id",
        "version"
      ],
      "type": "object"
    },
    "ProtocolImplementationDeclaration": {
      "properties": {
        "conformance_vectors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "profiles": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "protocol_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "protocol_id",
        "version"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "annotations": {
      "additionalProperties": true,
      "type": "object"
    },
    "artifact": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "behavior": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "capability_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "claim_status": {
      "$ref": "#/$defs/ComponentClaimStatus"
    },
    "component_id": {
      "type": "string"
    },
    "content_roots": {
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "enforced_boundaries": {
      "$ref": "#/$defs/ComponentBoundaryClaims"
    },
    "entry_kind": {
      "type": "string"
    },
    "protocol_implementations": {
      "items": {
        "$ref": "#/$defs/PackagedProtocolDescriptor"
      },
      "type": "array"
    },
    "surfaces": {
      "items": {
        "$ref": "#/$defs/PackagedSurfaceDescriptor"
      },
      "type": "array"
    },
    "trust_class": {
      "$ref": "#/$defs/ComponentTrustClass"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "artifact",
    "behavior",
    "capability_ids",
    "claim_status",
    "component_id",
    "enforced_boundaries",
    "entry_kind",
    "trust_class",
    "version"
  ],
  "title": "ComponentDescriptor",
  "type": "object"
}
