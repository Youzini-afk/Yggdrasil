{
  "$defs": {
    "ContractDiagnostic": {
      "properties": {
        "canonical_id": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "deprecated_in": {
          "type": [
            "string",
            "null"
          ]
        },
        "maturity": {
          "$ref": "#/$defs/ContractMaturity"
        },
        "message": {
          "type": "string"
        },
        "replacement": {
          "type": [
            "string",
            "null"
          ]
        },
        "requested_id": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "support_until": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "canonical_id",
        "code",
        "maturity",
        "message",
        "requested_id",
        "severity"
      ],
      "type": "object"
    },
    "ContractMaturity": {
      "enum": [
