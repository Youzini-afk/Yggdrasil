{
  "$defs": {
    "Errors": {
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "code": {
            "type": "string"
          },
          "details": true,
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "details",
          "message"
        ],
        "title": "ErrorShape",
        "type": "object"
      },
      "type": "array"
    },
    "ExecutionTargetCapability": {
      "enum": [
        "local_exec",
        "port_lease",
        "http_proxy_upstream",
        "websocket_proxy_upstream",
        "artifact_transfer",
        "declarative_verifier",
        "health_probe",
        "deployment",
        "authenticated_tunnel"
      ],
      "type": "string"
    },
    "ExecutionTargetObservedSummary": {
      "properties": {
        "artifact_count": {
          "default": 0,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "running_operation_count": {
          "default": 0,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "workload_count": {
          "default": 0,
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "ExecutionTargetReachability": {
      "enum": [
        "local_host",
        "direct",
        "reverse_tunnel"
      ],
      "type": "string"
    },
    "ExecutionTargetStatusKind": {
      "oneOf": [
        {
          "enum": [
            "enrolling",
            "available",
            "degraded",
            "offline",
            "draining",
            "incompatible",
            "revoked"
          ],
          "type": "string"
        },
        {
          "description": "Compatibility state used by older local target adapters.",
          "enum": [
            "unavailable"
          ],
          "type": "string"
        }
      ]
    },
    "Params": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "EmptyParams",
      "type": "object"
    },
    "Result": {
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "capabilities": {
            "default": [],
            "description": "Effective capabilities after protocol negotiation and Host policy.",
            "items": {
              "$ref": "#/$defs/ExecutionTargetCapability"
            },
            "type": "array"
          },
          "declared_capabilities": {
            "default": [],
            "description": "Capabilities declared by the target before Host policy is applied.",
            "items": {
              "$ref": "#/$defs/ExecutionTargetCapability"
            },
            "type": "array"
          },
          "enrolled_at_ms": {
            "format": "int64",
            "type": [
              "integer",
              "null"
            ]
          },
          "heartbeat_expires_at_ms": {
            "format": "int64",
            "type": [
              "integer",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "identity_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "labels": {
            "additionalProperties": {
              "type": "string"
            },
            "default": {},
            "type": "object"
          },
          "last_seen_at_ms": {
            "format": "int64",
            "type": [
              "integer",
              "null"
            ]
          },
          "lease_epoch": {
            "default": 0,
            "format": "uint64",
            "minimum": 0.0,
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "observed": {
            "anyOf": [
              {
                "$ref": "#/$defs/ExecutionTargetObservedSummary"
              },
              {
                "type": "null"
              }
            ]
          },
          "policy_epoch": {
            "default": 0,
            "format": "uint64",
            "minimum": 0.0,
            "type": "integer"
          },
          "protocol_versions": {
            "default": [],
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "reachability": {
            "$ref": "#/$defs/ExecutionTargetReachability"
          },
          "revoked_at_ms": {
            "format": "int64",
            "type": [
              "integer",
              "null"
            ]
          },
          "selected_protocol_version": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "$ref": "#/$defs/ExecutionTargetStatusKind"
          }
        },
        "required": [
          "id",
          "name",
          "reachability",
          "status"
        ],
        "title": "ExecutionTarget",
        "type": "object"
      },
      "type": "array"
    }
  },
  "$id": "https://yggdrasil.dev/spec/v1/methods/kernel.v1.target.list.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Yggdrasil public kernel method kernel.v1.target.list.",
  "properties": {
    "errors": {
      "$ref": "#/$defs/Errors"
    },
    "method": {
      "const": "kernel.v1.target.list"
    },
    "params": {
      "$ref": "#/$defs/Params"
    },
    "result": {
      "$ref": "#/$defs/Result"
    }
  },
  "required": [
    "method",
    "params"
  ],
  "title": "kernel.v1.target.list",
  "type": "object",
  "x-yggdrasil-contract": {
    "aliases": [
      {
        "canonical_id": "host.target.list",
        "deprecated_in": "ygg.contract.registry@0.4.0",
        "id": "kernel.v1.target.list",
        "introduced_in": "kernel.v1@0.1.0",
        "maturity": "legacy_adapter",
        "replacement": "host.target.list",
        "request_adapter": "identity",
        "response_adapter": "identity",
        "support_until": "ygg.contract.registry@0.5.0"
      }
    ],
    "canonical_id": "host.target.list",
    "implementation_status": "partial",
    "introduced_in": "ygg.contract.default/v1@0.1.0",
    "maturity": "candidate",
    "owner_layer": "host",
    "request_adapter": "identity",
    "request_schema": "https://yggdrasil.dev/spec/v1/methods/kernel.v1.target.list.schema.json#/$defs/Params",
    "response_adapter": "identity",
    "response_schema": "https://yggdrasil.dev/spec/v1/methods/kernel.v1.target.list.schema.json#/$defs/Result",
    "streaming": false
  }
}
