        "candidate",
        "stable",
        "deprecated",
        "legacy_adapter"
      ],
      "type": "string"
    },
    "ProtocolError": {
      "properties": {
        "code": {
          "type": "string"
        },
        "details": {
          "default": null
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/ContractDiagnostic"
      },
      "type": "array"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProtocolError"
        },
        {
          "type": "null"
        }
      ]
    },
    "id": {
      "type": "string"
    },
    "result": true
  },
  "required": [
    "id"
  ],
  "title": "ProtocolResponse",
  "type": "object"
}
