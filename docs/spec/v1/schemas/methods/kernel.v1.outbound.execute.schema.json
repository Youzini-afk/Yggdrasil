{
  "$defs": {
    "Errors": {
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "properties": {
          "code": {
            "type": "string"
          },
          "details": true,
          "message": {
            "type": "string"
          }
        },
        "required": [
          "code",
          "details",
          "message"
        ],
        "title": "ErrorShape",
        "type": "object"
      },
      "type": "array"
    },
    "Params": {
      "$defs": {
        "OutboundSecretHeaderSpec": {
          "description": "Specification for a secret-derived HTTP header to be injected by the host during outbound execution. Packages declare these in `kernel.v1.outbound.execute` params as `secret_headers`; the host resolves the `secret_ref` at execution time and injects the resulting header value into the live HTTP request.\n\nRaw secret values never appear in audit, response, or Debug output.",
          "properties": {
            "header_name": {
              "type": "string"
            },
            "scheme": {
              "type": "string"
            },
            "secret_ref": {
              "type": "string"
            }
          },
          "required": [
            "header_name",
            "scheme",
            "secret_ref"
          ],
          "type": "object"
        },
        "OutboundStaticHeader": {
          "description": "A safe non-secret static header for outbound requests (L5).\n\nOnly header names on the `STATIC_HEADER_ALLOWLIST` are permitted. Secret-bearing header names (Authorization, x-api-key, Cookie, etc.) are rejected at parse time. Values must be plain strings that do not look like raw secrets.",
          "properties": {
            "name": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "value"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "body_shape": true,
        "capability_id": {
          "type": "string"
        },
        "destination_host": {
          "type": "string"
        },
        "metadata": true,
        "method": {
          "type": "string"
        },
        "package_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "purpose": {
          "type": [
            "string",
            "null"
          ]
        },
        "secret_headers": {
          "items": {
            "$ref": "#/definitions/OutboundSecretHeaderSpec"
          },
          "type": "array"
        },
        "secret_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "static_headers": {
          "items": {
            "$ref": "#/definitions/OutboundStaticHeader"
          },
          "type": "array"
        },
        "timeout_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "body_shape",
        "capability_id",
        "destination_host",
        "metadata",
        "method",
        "secret_headers",
        "secret_refs",
        "static_headers"
      ],
      "title": "OutboundExecuteParams",
      "type": "object"
    },
    "Result": {
      "$defs": {
        "ExecutorKind": {
          "description": "The kind of outbound executor that produced a response.",
          "oneOf": [
            {
              "description": "All outbound is denied; no network performed.",
              "enum": [
                "deny_all"
              ],
              "type": "string"
            },
            {
              "description": "Fake/deterministic fixture executor; no real network.",
              "enum": [
                "fake"
              ],
              "type": "string"
            },
            {
              "description": "Real network executor (future M4+).",
              "enum": [
                "real"
              ],
              "type": "string"
            }
          ]
        },
        "RedactionState": {
          "description": "Redaction state for an outbound audit record.\n\nEvery outbound request carries one of these states to indicate whether raw body/header/prompt/response data was preserved. The default is `NotCaptured` — raw data is never saved unless explicitly approved.",
          "oneOf": [
            {
              "description": "Raw data was not captured (default).",
              "enum": [
                "not_captured"
              ],
              "type": "string"
            },
            {
              "description": "Raw data was redacted before recording.",
              "enum": [
                "redacted"
              ],
              "type": "string"
            },
            {
              "description": "Only a policy reference is stored; no data captured.",
              "enum": [
                "policy_ref"
              ],
              "type": "string"
            },
            {
              "description": "Request was blocked as unsafe; no data recorded.",
              "enum": [
                "unsafe_blocked"
              ],
              "type": "string"
            },
            {
              "description": "Explicit user/host approval to capture raw data (rare).",
              "enum": [
                "explicitly_approved"
              ],
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Response returned by an outbound executor.\n\nLike the request, this is content-free. It carries status, the *shape* of headers/body, usage/cost placeholders, and metadata identifying what kind of executor produced the response.",
      "properties": {
        "body_shape": {
          "default": null,
          "description": "JSON *shape* of the response body."
        },
        "cost": {
          "default": null,
          "description": "Cost placeholder (e.g. `{\"total_cost_usd\": 0.002}`)."
        },
        "executor_kind": {
          "allOf": [
            {
              "$ref": "#/definitions/ExecutorKind"
            }
          ],
          "description": "What kind of executor produced this response."
        },
        "headers_shape": {
          "default": null,
          "description": "JSON *shape* of the response headers (e.g. `{\"content-type\": \"application/json\", \"x-ratelimit-remaining\": \"...\"}`)."
        },
        "network_performed": {
          "description": "Whether real network I/O was performed.",
          "type": "boolean"
        },
        "provider_request_id": {
          "default": null,
          "description": "Provider-assigned request id (e.g. `req-abc123`).",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_state": {
          "allOf": [
            {
              "$ref": "#/definitions/RedactionState"
            }
          ],
          "default": "not_captured",
          "description": "Redaction state applied to the response."
        },
        "status": {
          "description": "High-level status: \"ok\", \"error\", \"denied\", \"timeout\".",
          "type": "string"
        },
        "status_code": {
          "default": null,
          "description": "HTTP-style status code if applicable (e.g. 200, 429, 503).",
          "format": "uint16",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "usage": {
          "default": null,
          "description": "Usage placeholder (e.g. `{\"prompt_tokens\": 10, \"completion_tokens\": 20}`)."
        }
      },
      "required": [
        "executor_kind",
        "network_performed",
        "status"
      ],
      "title": "OutboundExecutorResponse",
      "type": "object"
    }
  },
  "$id": "https://yggdrasil.dev/spec/v1/methods/kernel.v1.outbound.execute.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Yggdrasil public kernel method kernel.v1.outbound.execute.",
  "properties": {
    "errors": {
      "$ref": "#/$defs/Errors"
    },
    "method": {
      "const": "kernel.v1.outbound.execute"
    },
    "params": {
      "$ref": "#/$defs/Params"
    },
    "result": {
      "$ref": "#/$defs/Result"
    }
  },
  "required": [
    "method",
    "params"
  ],
  "title": "kernel.v1.outbound.execute",
  "type": "object"
}
