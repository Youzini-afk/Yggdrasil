{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "ComponentLockPin": {
      "properties": {
        "behavior_digest": {
          "type": "string"
        },
        "component_id": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "trust_class": {
          "$ref": "#/$defs/ComponentTrustClass"
        }
      },
      "required": [
        "behavior_digest",
        "component_id",
        "digest",
        "trust_class"
      ],
      "type": "object"
    },
    "ComponentTrustClass": {
      "enum": [
        "sandboxed_component",
        "isolated_process",
        "remote_boundary",
        "trusted_native",
        "static_resource",
        "foreign_capsule"
      ],
      "type": "string"
    },
    "ProtocolProfilePin": {
      "properties": {
        "profile": {
          "type": "string"
        },
        "protocol_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "profile",
        "protocol_id",
        "version"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "components": {
      "items": {
        "$ref": "#/$defs/ComponentLockPin"
      },
      "type": "array"
    },
    "content_roots": {
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "protocol_profiles": {
      "items": {
        "$ref": "#/$defs/ProtocolProfilePin"
      },
      "type": "array"
    },
    "schema": {
      "type": "string"
    }
  },
  "required": [
    "components",
    "content_roots",
    "protocol_profiles",
    "schema"
  ],
  "title": "CompositionLock",
  "type": "object"
}
