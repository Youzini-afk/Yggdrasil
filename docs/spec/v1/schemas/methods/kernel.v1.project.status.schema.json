    "Result": {
      "$defs": {
        "ProjectState": {
          "description": "Runtime project state. Not serialized to project.yaml; tracked by registry.",
          "oneOf": [
            {
              "description": "Installed but not running.",
              "enum": [
                "installed"
              ],
              "type": "string"
            },
            {
              "description": "Stopped after running.",
              "enum": [
                "stopped"
              ],
              "type": "string"
            },
            {
              "description": "Currently transitioning to running.",
              "enum": [
                "starting"
              ],
              "type": "string"
            },
            {
              "description": "Currently running and serving.",
              "enum": [
                "running"
              ],
              "type": "string"
            },
            {
              "description": "Currently transitioning to stopped.",
              "enum": [
                "stopping"
              ],
              "type": "string"
            },
            {
              "description": "Failed to start or crashed.",
              "enum": [
                "failed"
              ],
              "type": "string"
            },
            {
              "description": "Soft-deleted, awaiting cleanup.",
              "enum": [
                "archived"
              ],
              "type": "string"
            }
          ]
        },
        "ProjectStorageSummarySchema": {
          "properties": {
            "bundle_bytes": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "cache_bytes": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "data_bytes": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "log_bytes": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "measured_at": {
              "format": "date-time",
              "type": [
                "string",
                "null"
              ]
            },
            "measurement_state": {
              "$ref": "#/definitions/StorageMeasurementStateSchema"
            },
            "total_bytes": {
              "format": "uint64",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [
            "measurement_state"
          ],
          "type": "object"
        },
        "StorageMeasurementStateSchema": {
          "enum": [
            "measured",
            "unknown"
          ],
          "type": "string"
        }
