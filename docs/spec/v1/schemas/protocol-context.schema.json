{
  "$defs": {
    "ProtocolAuthorityContext": {
      "properties": {
        "actions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "delegation_chain": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "grant_id": {
          "type": "string"
        },
        "resources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ProtocolResourceSelector"
          },
          "type": "array"
        }
      },
      "required": [
        "grant_id"
      ],
      "type": "object"
    },
    "ProtocolHostOperationContext": {
      "description": "Request-specific Host operation facts established by a trusted transport adapter after it has parsed and authorized the request. Unlike authority, this is never populated from the request body itself.",
      "properties": {
        "action": {
          "type": "string"
        },
        "resources": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ProtocolResourceSelector"
          },
          "type": "array"
        }
      },
      "required": [
        "action"
      ],
      "type": "object"
    },
    "ProtocolPrincipal": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "host_admin"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "host_dev"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "package"
              ],
              "type": "string"
            },
            "package_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "package_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "human"
              ],
              "type": "string"
            },
            "user_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "user_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "assistant_id": {
              "type": "string"
            },
            "delegated_user_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "assistant"
              ],
              "type": "string"
            }
          },
          "required": [
            "assistant_id",
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "anonymous"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    },
    "ProtocolResourceSelector": {
      "properties": {
        "id": {
          "description": "An omitted id selects every resource of this owner/kind. Resource matching is structural and exact; callers must never use string-prefix matching for authority decisions.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "owner"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "authority": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProtocolAuthorityContext"
        },
        {
          "type": "null"
        }
      ],
      "description": "Authenticated Host authority carried by transport adapters. This is additive so older callers remain source- and wire-compatible. Device calls use the existing anonymous V1 principal as a fail-closed sentinel: old runtimes ignore this field and deny the call, while new runtimes require the scoped authority below."
    },
    "correlation_id": {
      "default": null,
      "format": "uuid",
      "type": [
        "string",
        "null"
      ]
    },
    "host_operation": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProtocolHostOperationContext"
        },
        {
          "type": "null"
        }
      ]
    },
    "parent_invocation_id": {
      "default": null,
      "format": "uuid",
      "type": [
        "string",
        "null"
      ]
    },
    "principal": {
      "$ref": "#/$defs/ProtocolPrincipal"
    },
    "session_id": {
      "description": "Optional kernel session id this call is operating under. Used by outbound dispatch to scope secret resolution to the session's project.",
      "type": [
        "string",
        "null"
      ]
    },
    "transport": {
      "type": "string"
    }
  },
  "required": [
    "principal",
    "transport"
  ],
  "title": "ProtocolContext",
  "type": "object"
}
