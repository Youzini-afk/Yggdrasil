{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "PolicyDecisionOutcome": {
      "enum": [
        "allowed",
        "denied",
        "requires_approval"
      ],
      "type": "string"
    },
    "PrincipalIdentity": {
      "oneOf": [
        {
          "properties": {
            "kind": {
              "enum": [
                "kernel"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "host_admin"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "host_dev"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "package"
              ],
              "type": "string"
            },
            "package_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "package_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "human"
              ],
              "type": "string"
            },
            "user_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "user_id"
          ],
          "type": "object"
        },
        {
          "properties": {
            "assistant_id": {
              "type": "string"
            },
            "delegated_user_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "assistant"
              ],
              "type": "string"
            }
          },
          "required": [
            "assistant_id",
            "kind"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "enum": [
                "anonymous"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "change_set_id": {
      "type": "string"
    },
    "decided_at": {
      "format": "date-time",
      "type": "string"
    },
    "decision_type_uri": {
      "default": "urn:yggdrasil:policy-decision:v1",
      "type": "string"
    },
    "evaluated_authority": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "id": {
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/PolicyDecisionOutcome"
    },
    "policy_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        {
          "type": "null"
        }
      ]
    },
    "principal": {
      "$ref": "#/$defs/PrincipalIdentity"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "change_set_id",
    "decided_at",
    "id",
    "outcome",
    "principal"
  ],
  "title": "PolicyDecision",
  "type": "object"
}
