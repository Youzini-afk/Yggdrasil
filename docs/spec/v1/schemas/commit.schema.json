{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "ChangeCommitStatus": {
      "enum": [
        "committed",
        "failed",
        "partial"
      ],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "branch_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "change_set_id": {
      "type": "string"
    },
    "commit_type_uri": {
      "default": "urn:yggdrasil:change-commit:v1",
      "type": "string"
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "operation_receipts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "result_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "started_at": {
      "format": "date-time",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ChangeCommitStatus"
    }
  },
  "required": [
    "change_set_id",
    "completed_at",
    "id",
    "started_at",
    "status"
  ],
  "title": "ChangeCommit",
  "type": "object"
}
