      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "project_id": {
          "type": "string"
        },
        "running_session_id": {
          "type": "string"
        },
        "secrets_count": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "sessions_count": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "state": {
          "$ref": "#/definitions/ProjectState"
        },
        "storage_summary": {
          "anyOf": [
            {
              "$ref": "#/definitions/ProjectStorageSummarySchema"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "project_id",
        "running_session_id",
        "secrets_count",
        "sessions_count",
        "state"
