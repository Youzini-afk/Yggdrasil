{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "EffectReplayMode": {
      "enum": [
        "live",
        "historical",
        "reexecute"
      ],
      "type": "string"
    },
    "Payload": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "capability_id": {
          "type": "string"
        },
        "correlation_id": {
          "format": "uuid",
          "type": "string"
        },
        "duration_ms": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        },
        "output": true,
        "provider_package_id": {
          "type": "string"
        },
        "receipt": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactDescriptor"
            },
            {
              "type": "null"
            }
          ]
        },
        "replay_mode": {
          "anyOf": [
            {
              "$ref": "#/$defs/EffectReplayMode"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "capability_id",
        "correlation_id",
        "duration_ms",
        "output",
        "provider_package_id"
      ],
      "title": "CapabilityInvocationResult",
      "type": "object"
    }
  },
  "$id": "https://yggdrasil.dev/spec/v1/events/kernel__v1__capability.completed.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Payload schema for event kind kernel/v1/capability.completed.",
  "properties": {
    "kind": {
      "const": "kernel/v1/capability.completed"
    },
    "payload": {
      "$ref": "#/$defs/Payload"
    }
  },
  "title": "kernel/v1/capability.completed",
  "type": "object"
}
