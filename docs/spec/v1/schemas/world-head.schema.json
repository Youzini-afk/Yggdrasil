{
  "$defs": {
    "ArtifactDescriptor": {
      "properties": {
        "annotations": {
          "additionalProperties": true,
          "default": {},
          "type": "object"
        },
        "artifact_type_uri": {
          "type": "string"
        },
        "digest": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "references": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "artifact_type_uri",
        "digest",
        "media_type",
        "size_bytes"
      ],
      "type": "object"
    },
    "ProtocolProfilePin": {
      "properties": {
        "profile": {
          "type": "string"
        },
        "protocol_id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "profile",
        "protocol_id",
        "version"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "annotations": {
      "additionalProperties": true,
      "type": "object"
    },
    "composition_lock": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "effect_receipts": {
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "head_type_uri": {
      "type": "string"
    },
    "history_root": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "parent_heads": {
      "items": {
        "$ref": "#/$defs/ArtifactDescriptor"
      },
      "type": "array"
    },
    "policy_root": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactDescriptor"
        },
        {
          "type": "null"
        }
      ]
    },
    "protocol_profiles": {
      "items": {
        "$ref": "#/$defs/ProtocolProfilePin"
      },
      "type": "array"
    },
    "provenance_root": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "schema_version": {
      "format": "uint16",
      "minimum": 0.0,
      "type": "integer"
    },
    "state_root": {
      "$ref": "#/$defs/ArtifactDescriptor"
    },
    "world_id": {
      "type": "string"
    }
  },
  "required": [
    "composition_lock",
    "head_type_uri",
    "history_root",
    "protocol_profiles",
    "provenance_root",
    "schema_version",
    "state_root",
    "world_id"
  ],
  "title": "WorldHead",
  "type": "object"
}
