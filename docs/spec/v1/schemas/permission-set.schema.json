  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "assets": {
      "allOf": [
        {
          "$ref": "#/$defs/AssetPermissions"
        }
      ],
      "default": {
        "read": false,
        "write": false
      }
    },
    "capabilities": {
      "allOf": [
